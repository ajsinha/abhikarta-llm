{
  "provider": "google",
  "api_version": "v1",
  "base_url": "https://generativelanguage.googleapis.com",
  "models": [
    {
      "name": "gemini-pro",
      "version": "1.0",
      "description": "Google's most capable Gemini model",
      "strengths": ["reasoning", "multi-turn", "general-purpose"],
      "context_window": 32768,
      "max_output": 8192,
      "cost": {
        "input_per_1k": 0.00025,
        "output_per_1k": 0.0005
      },
      "capabilities": {
        "chat": true,
        "completion": true,
        "streaming": true,
        "function_calling": true,
        "vision": false
      }
    },
    {
      "name": "gemini-pro-vision",
      "version": "1.0",
      "description": "Gemini model with vision capabilities",
      "strengths": ["vision", "multi-modal", "image-understanding"],
      "context_window": 16384,
      "max_output": 4096,
      "cost": {
        "input_per_1k": 0.00025,
        "output_per_1k": 0.0005
      },
      "capabilities": {
        "chat": true,
        "completion": true,
        "streaming": true,
        "function_calling": false,
        "vision": true
      }
    }
  ]
}
