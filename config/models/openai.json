    "json_mode": "Structured output via response_format parameter for JSON object or JSON schema",
    "batch_api": "Batch API available for asynchronous processing at 50% discount",
    "assistants_api": "Stateful assistant API with tools, file search, and code interpreter",
    "realtime_api": "WebSocket API for real-time audio and text interactions (GPT-4o realtime models)",
    "moderation": "Free content moderation API for detecting harmful content",
    "embeddings": "Multiple embedding models available for semantic search and RAG applications",
    "audio": "Whisper for speech-to-text, TTS for text-to-speech, realtime for bidirectional audio",
