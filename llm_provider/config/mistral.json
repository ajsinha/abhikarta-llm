    "fine_tuning": "Fine-tuning available for select models",
    "embeddings": "Mistral Embed for semantic search and RAG",
    "moderation": "Content moderation capabilities built into models",
    "vision": "Pixtral models for multimodal image understanding",
    "coding": "Codestral specialized for code generation",
    "sdk_support": "Official SDKs for Python, TypeScript, JavaScript",
