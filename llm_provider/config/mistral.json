    "european_ai": "European AI company focused on frontier AI models",
    "open_source": "Some models available open-source (Mistral 7B, Mixtral 8x7B)",
    "function_calling": "Native function calling supported on all instruction models",
    "json_mode": "Structured JSON output via response_format parameter",
    "multilingual": "Strong multilingual support across European and global languages",
