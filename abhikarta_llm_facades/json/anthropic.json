    "message_batches": "Batch API available for processing up to 10,000 requests with 50% cost reduction and 24-hour processing",
    "vision": "Claude 3 family supports image inputs (PNG, JPEG, WEBP, GIF). Max 5MB per image, multiple images per message",
    "function_calling": "Tool use (function calling) supported on all Claude 3 models via tools parameter",
    "system_prompts": "Support for system prompts to set context, role, and instructions",
    "thinking_tokens": "Extended thinking models output reasoning tokens before final response",
    "json_mode": "No dedicated JSON mode, but models excel at structured output with proper prompting",
    "sdk_support": "Official SDKs for Python and TypeScript. Community SDKs available for other languages",
    "max_tokens_parameter": "Required parameter specifying maximum output tokens. Models won't exceed this limit",
    "anthropic_version": "Required header specifying API version (e.g., '2023-06-01')",
    "token_counting": "Use token counting API to estimate costs before requests",
    "constitutional_ai": "Models trained with Constitutional AI for helpfulness, harmlessness, and honesty",
    "workbench": "Claude console provides workbench for prompt engineering and testing",
    "prompt_improver": "Built-in prompt improvement tools in console for optimization",
    "beta_features": "Some features like prompt caching require anthropic-beta header"
