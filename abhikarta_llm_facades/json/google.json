    "multimodal": "Gemini models support text, images, audio, video, and PDF inputs in a single request",
    "grounding": "Vertex AI supports grounding with Google Search and custom data sources",
    "function_calling": "Supported via function declarations with automatic parallel execution",
    "code_execution": "Built-in Python code interpreter for Gemini models",
    "thinking_mode": "Gemini 2.0 Flash Thinking supports extended reasoning for complex problems",
    "json_mode": "Structured output via response_mime_type and response_schema",
    "safety_settings": "Configurable content filtering for harassment, hate speech, sexually explicit, and dangerous content",
