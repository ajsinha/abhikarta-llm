    "caching": "Context caching available on Gemini 1.5 Pro and Flash to reduce costs",
    "tuning": "Fine-tuning available for select models via supervised tuning",
    "batch_api": "Batch prediction API available on Vertex AI for asynchronous processing",
    "embedding_models": "Text, image, and multimodal embedding models for semantic search",
    "imagen": "Image generation models available on Vertex AI",
    "speech_models": "Chirp speech-to-text models for audio transcription",
    "model_garden": "Access to 100+ open-source models via Vertex AI Model Garden",
    "ai_studio": "Web-based IDE for prompt development and testing",
    "vertex_ai": "Enterprise platform with VPC, encryption, audit logs, and SLA"
